{
  "name": "mdv",
  "version": "0.3.0",
  "description": "Markdown Viewer with Marp support",
  "main": "src/server.js",
  "bin": {
    "mdv": "./bin/mdv.js"
  },
  "scripts": {
    "start": "node bin/mdv.js",
    "dev": "node bin/mdv.js --dev",
    "test": "node --test tests/*.js"

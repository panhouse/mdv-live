{
  "name": "mdv-live",
  "version": "0.6.8",
  "description": "Markdown Viewer - File tree + Live preview + Marp support + Hot reload + change-review surface (full-text search, diff highlighting, unread tracking)",
  "main": "src/server.js",
  "bin": {
    "mdv": "./bin/mdv.js"
  },
  "scripts": {
    "start": "node bin/mdv.js",
    "dev": "node bin/mdv.js",
    "test": "node --test tests/*.js",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "setup-macos": "bash scripts/setup-macos-app.sh"
  },
  "keywords": [
    "markdown",
    "viewer",
    "marp",
    "slides",
    "preview",
    "live-reload",
    "hot-reload",
    "file-tree",
    "diff",
    "search",
    "review"
  ],
  "author": "PanHouse <hirono.okamoto@panhouse.jp>",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panhouse/mdv-live.git"
  },
  "homepage": "https://github.com/panhouse/mdv-live#readme",
  "bugs": {
    "url": "https://github.com/panhouse/mdv-live/issues"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@marp-team/marp-core": "^4.0.0",
    "chokidar": "^4.0.3",
    "express": "^4.21.2",
    "fflate": "^0.8.3",
    "highlight.js": "^11.10.0",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1",
    "mime-types": "^2.1.35",
    "multer": "^2.2.0",
    "open": "^10.1.0",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "@marp-team/marp-cli": "^4.0.3",
    "md-to-pdf": "^5.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@highlightjs/cdn-assets": "^11.11.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.6.0",
    "html2pdf.js": "^0.14.0",
    "mermaid": "^11.15.0"
  }
}

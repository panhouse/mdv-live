{
  "name": "mdv-live",
  "version": "0.5.1",
  "description": "Markdown Viewer - File tree + Live preview + Marp support + Hot reload",
  "main": "src/server.js",
  "bin": {
    "mdv": "./bin/mdv.js"
  },
  "scripts": {
    "start": "node bin/mdv.js",
    "dev": "node bin/mdv.js --dev",
    "test": "node --test tests/*.js",
    "setup-macos": "bash scripts/setup-macos-app.sh"
  },
  "keywords": [
    "markdown",
    "viewer",
    "marp",
    "slides",
    "preview",
    "live-reload",
    "hot-reload",
    "file-tree"
  ],
  "author": "PanHouse <hirono.okamoto@panhouse.jp>",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panhouse/mdv-live.git"
  },
  "homepage": "https://github.com/panhouse/mdv-live#readme",
  "bugs": {
    "url": "https://github.com/panhouse/mdv-live/issues"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "express": "^4.21.2",
    "ws": "^8.18.0",
    "chokidar": "^4.0.3",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1",
    "@marp-team/marp-core": "^4.0.0",
    "highlight.js": "^11.10.0",
    "open": "^10.1.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1"
  },
  "optionalDependencies": {
    "@marp-team/marp-cli": "^4.0.3"
  }
}
